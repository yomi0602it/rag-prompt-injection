# ===========================================
# RAG Prompt Injection Prototype - Environment
# ===========================================

# AWS Configuration (configured via AWS CLI or IAM Roles in production)
AWS_REGION="us-east-1"

# Vector Database Endpoint (output from: terraform apply)
OPENSEARCH_ENDPOINT="https://[YOUR-COLLECTION-ID].us-east-1.aoss.amazonaws.com"

# Bedrock Model IDs
BEDROCK_EMBEDDING_MODEL="amazon.titan-embed-text-v2:0"
BEDROCK_LLM_MODEL="meta.llama3-8b-instruct-v1:0"

# Retrieval Configuration
RETRIEVER_TOP_K=3
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
